SliderBtn.BorderSizePixel = 0
SliderBtn.Parent = SliderTrack
Instance.new("UICorner", SliderBtn).CornerRadius = UDim.new(1, 0)

-- Slider Logic
local sliding = false
local MIN_VAL, MAX_VAL = 1, 15

local function updateSlider(x)
	local trackPos = SliderTrack.AbsolutePosition.X
	local trackSize = SliderTrack.AbsoluteSize.X
	local ratio = math.clamp((x - trackPos) / trackSize, 0, 1)
	MAX_PLAYERS = math.floor(MIN_VAL + ratio * (MAX_VAL - MIN_VAL))
	SliderFill.Size = UDim2.new(ratio, 0, 1, 0)
	SliderBtn.Position = UDim2.new(ratio, 0, 0.5, 0)
	SliderLabel.Text = "👥 Maks Player: " .. MAX_PLAYERS
end

SliderBtn.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or
		input.UserInputType == Enum.UserInputType.Touch then
		sliding = true
	end
end)

SliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or
		input.UserInputType == Enum.UserInputType.Touch then
		sliding = true
		updateSlider(input.Position.X)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or
		input.UserInputType == Enum.UserInputType.Touch) then
		updateSlider(input.Position.X)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or
		input.UserInputType == Enum.UserInputType.Touch then
		sliding = false
	end
end)

-- Fetch dengan filter ketat
local function fetchQuietServer()
	local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
	local ok, result = pcall(function()
		return game:HttpGet(url)
	end)
	if not ok then return nil, "HttpGet gagal" end

	local data = HttpService:JSONDecode(result)
	if not data or not data.data or #data.data == 0 then
		return nil, "Tidak ada server ditemukan"
	end

	-- Kumpulkan semua server yang memenuhi syarat
	local validServers = {}

	for _, server in ipairs(data.data) do
		local count = server.playing or 0
		local max   = server.maxPlayers or 1
		local isCurrent = server.id == currentJobId

		-- Filter ketat: tidak current, di bawah batas, tidak penuh
		if not isCurrent and count <= MAX_PLAYERS and count < max then
			table.insert(validServers, {id = server.id, count = count})
		end
	end

	if #validServers == 0 then
		return nil, "Tidak ada server dengan ≤ " .. MAX_PLAYERS .. " player"
	end

	-- Sort by player count ascending
	table.sort(validServers, function(a, b) return a.count < b.count end)

	-- Ambil yang paling sepi
	local best = validServers[1]
	return best.id, best.count
end

FindBtn.MouseButton1Click:Connect(function()
	if searching then return end
	searching = true
	JoinBtn.Visible = false
	foundJobId = nil

	FindBtn.Text = "⏳  Mencari..."
	FindBtn.BackgroundColor3 = Color3.fromRGB(30, 100, 60)
	InfoText.Text = "🔄 Mencari server ≤ " .. MAX_PLAYERS .. " player..."
	InfoText.TextColor3 = Color3.fromRGB(255, 210, 80)

	task.spawn(function()
		local jobId, info = fetchQuietServer()

		if jobId then
			foundJobId = jobId
			InfoText.Text = "✅ Ketemu! " .. info .. " player di server ini"
			InfoText.TextColor3 = Color3.fromRGB(80, 220, 120)
			FindBtn.Text = "🔍  Cari Lagi"
			FindBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 100)
			JoinBtn.Visible = true
		else
			InfoText.Text = "❌ " .. tostring(info)
			InfoText.TextColor3 = Color3.fromRGB(255, 80, 80)
			FindBtn.Text = "🔍  Cari Server Sepi"
			FindBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 100)
		end

		searching = false
	end)
end)

JoinBtn.MouseButton1Click:Connect(function()
	if not foundJobId then return end
	InfoText.Text = "🚀 Joining server..."
	InfoText.TextColor3 = Color3.fromRGB(100, 180, 255)
	JoinBtn.Text = "⏳  Teleporting..."

	local ok, err = pcall(function()
		TeleportService:TeleportToPlaceInstance(placeId, foundJobId, player)
	end)

	if not ok then
		InfoText.Text = "❌ Gagal join"
		InfoText.TextColor3 = Color3.fromRGB(255, 80, 80)
		JoinBtn.Text = "🚀  Join Sekarang"
	end
end)

