LaunchCorner.CornerRadius = UDim.new(0, 12)
LaunchCorner.Parent = LaunchBtn

-- Button gradient
local LaunchGradient = Instance.new("UIGradient")
LaunchGradient.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(120, 80, 255)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(70, 50, 200))
})
LaunchGradient.Rotation = 90
LaunchGradient.Parent = LaunchBtn

-- // DRAGGING //
local dragging, dragInput, dragStart, startPos

local function updateDrag(input)
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(
		startPos.X.Scale, startPos.X.Offset + delta.X,
		startPos.Y.Scale, startPos.Y.Offset + delta.Y
	)
end

TopBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

TopBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		updateDrag(input)
	end
end)

-- // BUTTON HOVER //
LaunchBtn.MouseEnter:Connect(function()
	TweenService:Create(LaunchBtn, TweenInfo.new(0.2), {
		BackgroundColor3 = Color3.fromRGB(110, 85, 255)
	}):Play()
end)

LaunchBtn.MouseLeave:Connect(function()
	TweenService:Create(LaunchBtn, TweenInfo.new(0.2), {
		BackgroundColor3 = Color3.fromRGB(90, 65, 230)
	}):Play()
end)

-- // CLOSE //
CloseBtn.MouseButton1Click:Connect(function()
	TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0)
	}):Play()
	task.delay(0.35, function()
		ScreenGui:Destroy()
	end)
end)

-- // LAUNCH LOGIC //
local launching = false

LaunchBtn.MouseButton1Click:Connect(function()
	if launching then return end
	launching = true

	LaunchBtn.Text = "⏳  Creating Server..."
	LaunchBtn.BackgroundColor3 = Color3.fromRGB(60, 55, 120)
	StatusText.Text = "🔄 Reserving server..."
	StatusText.TextColor3 = Color3.fromRGB(255, 210, 80)

	local success, result = pcall(function()
		local code = TeleportService:ReserveServer(PLACE_ID)
		StatusText.Text = "✅ Server reserved! Teleporting..."
		StatusText.TextColor3 = Color3.fromRGB(80, 220, 120)
		task.wait(0.8)
		TeleportService:TeleportToPrivateServer(PLACE_ID, code, {player})
	end)

	if not success then
		StatusText.Text = "❌ Failed: " .. tostring(result):sub(1, 40)
		StatusText.TextColor3 = Color3.fromRGB(255, 80, 80)
		LaunchBtn.Text = "🚀  Launch Private Server"
		LaunchBtn.BackgroundColor3 = Color3.fromRGB(90, 65, 230)
		launching = false
	end
end)

-- // ENTRANCE ANIMATION //
MainFrame.Size = UDim2.new(0, 0, 0, 0)
MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
	Size = UDim2.new(0, 300, 0, 220),
	Position = UDim2.new(0.5, -150, 0.5, -110)
}):Play()